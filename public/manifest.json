{
  "id": "/",
  "name": "Viral — Générateur de contenu viral IA",
  "short_name": "Viral",
  "description": "Créez du contenu viral pour TikTok, Instagram et Facebook en moins de 10 secondes grâce à l'IA.",
  "start_url": "/?source=pwa",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "tabbed", "standalone"],
  "orientation": "portrait-primary",
  "theme_color": "#3b82f6",
  "background_color": "#05080f",
  "categories": ["productivity", "social", "utilities"],
  "lang": "fr",
  "dir": "ltr",
  "prefer_related_applications": false,

  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ],

  "screenshots": [
    {
      "src": "/screenshots/desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Générateur de contenu viral sur desktop"
    },
    {
      "src": "/screenshots/mobile.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Viral sur mobile"
    }
  ],

  "shortcuts": [
    {
      "name": "Générer du contenu",
      "short_name": "Générer",
      "description": "Accéder directement au générateur viral",
      "url": "/app.html?source=shortcut",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Analyser mon compte",
      "short_name": "Analyser",
      "description": "Analyser votre compte avec l'IA",
      "url": "/analyze.html?source=shortcut",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    },
    {
      "name": "Ma bibliothèque",
      "short_name": "Bibliothèque",
      "description": "Voir vos contenus sauvegardés",
      "url": "/library.html?source=shortcut",
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }]
    }
  ],

  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },

  "file_handlers": [
    {
      "action": "/app.html",
      "accept": {
        "text/plain": [".txt"],
        "application/json": [".json"]
      },
      "icons": [{ "src": "/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }],
      "launch_type": "single-client"
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+viral",
      "url": "/app.html?theme=%s"
    }
  ],

  "share_target": {
    "action": "/app.html",
    "method": "GET",
    "params": {
      "title": "theme",
      "text": "theme",
      "url": "url"
    }
  },

  "note_taking": {
    "new_note_url": "/app.html?source=note"
  },

  "edge_side_panel": {
    "preferred_width": 400
  },

  "widgets": [
    {
      "name": "Viral — Générateur",
      "description": "Accédez rapidement au générateur de contenu viral",
      "tag": "viral-generator",
      "template": "viral-generator-template",
      "ms_ac_template": "/widgets/generator-widget.json",
      "data": "/api/widget/data",
      "type": "application/json",
      "auth": false,
      "update": 3600,
      "screenshots": [
        {
          "src": "/screenshots/mobile.png",
          "sizes": "390x844",
          "type": "image/png",
          "label": "Widget générateur Viral"
        }
      ],
      "icons": [
        {
          "src": "/icons/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ]
}
