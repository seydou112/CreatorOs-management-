{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "Container",
      "style": "emphasis",
      "bleed": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            {
              "type": "Column",
              "width": "auto",
              "items": [
                {
                  "type": "Image",
                  "url": "/icons/icon-192.png",
                  "size": "Small",
                  "style": "RoundedCorners"
                }
              ]
            },
            {
              "type": "Column",
              "width": "stretch",
              "items": [
                {
                  "type": "TextBlock",
                  "text": "Viral",
                  "weight": "Bolder",
                  "size": "Medium",
                  "color": "Accent"
                },
                {
                  "type": "TextBlock",
                  "text": "Générateur de contenu IA",
                  "size": "Small",
                  "isSubtle": true,
                  "spacing": "None"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "TextBlock",
      "text": "${tip}",
      "wrap": true,
      "size": "Small",
      "spacing": "Medium"
    },
    {
      "type": "FactSet",
      "facts": [
        { "title": "Plateformes", "value": "TikTok · Instagram · Facebook" },
        { "title": "Générations gratuites", "value": "3 par jour" },
        { "title": "IA", "value": "Gemini 2.0 Flash" }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "✦ Générer du contenu",
      "url": "/app.html?source=widget"
    },
    {
      "type": "Action.OpenUrl",
      "title": "📚 Ma bibliothèque",
      "url": "/library.html?source=widget"
    }
  ]
}
