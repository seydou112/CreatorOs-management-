GEMINI_API_KEY=votre-cle-gemini-ici

# Moneroo (paiements Mobile Money — Afrique)
# Clé API disponible sur : app.moneroo.io → Paramètres → API
MONEROO_API_KEY=
# Devise selon votre pays : XOF (Afrique de l'Ouest), XAF (Afrique Centrale),
# GHS (Ghana), NGN (Nigeria), GNF (Guinée), MGA (Madagascar)...
MONEROO_CURRENCY=XOF
# Prix en unité locale (ex: 2000 XOF ≈ 3 USD)
MONEROO_PRICE_MONTHLY=2000
MONEROO_PRICE_ANNUAL=18000
PORT=3000
NODE_ENV=development
FREE_DAILY_LIMIT=3

# Base de données PostgreSQL (ex: Neon.tech — gratuit)
DATABASE_URL=postgresql://user:password@host/dbname

# Authentification JWT
JWT_SECRET=une-chaine-aleatoire-tres-longue-et-secrete

# Stripe (paiements carte)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...
APP_URL=https://votre-app.onrender.com
